<?xml version="1.0" encoding="utf-8"?>
<!-- The embedded web server is plain HTTP by design, and Remote mode
     browses a user-configured desktop VellumFE over plain HTTP on a
     private network/VPN — a host unknowable at build time, so a static
     domain list can't express it. Cleartext is therefore permitted
     globally here and the real gate lives in MainActivity's WebView
     allowlist: only 127.0.0.1 and the paired remote host ever load
     in-app. Game/auth traffic is TLS or plain TCP at the Rust layer and
     unaffected by this policy. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
